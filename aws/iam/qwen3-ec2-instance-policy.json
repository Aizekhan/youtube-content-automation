{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowEC2SelfStop",
      "Effect": "Allow",
      "Action": [
        "ec2:StopInstances",
        "ec2:DescribeInstances",
        "ec2:DescribeInstanceStatus"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "ec2:ResourceTag/Service": "Qwen3-TTS"
        }
      }
    },
    {
      "Sid": "AllowS3AudioAccess",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::youtube-automation-audio-files",
        "arn:aws:s3:::youtube-automation-audio-files/*"
      ]
    },
    {
      "Sid": "AllowCloudWatchMetrics",
      "Effect": "Allow",
      "Action": [
        "cloudwatch:PutMetricData"
      ],
      "Resource": "*"
    }
  ]
}
