# Terraform Variables Example
# Скопіюйте цей файл як terraform.tfvars і заповніть своїми значеннями

# AWS Configuration
aws_region  = "eu-central-1"
environment = "prod"

# Project
project_name = "youtube-content-automation"

# Secrets (НЕ комітьте terraform.tfvars в git!)
openai_api_key = "sk-..." # Ваш OpenAI API Key

# Notion Integration (опціонально)
notion_api_key           = ""  # Notion API Token (ntn_...)
notion_tasks_database_id = ""  # Notion Database ID

# YouTube API (опціонально)
youtube_api_key = ""  # YouTube Data API Key

# Lambda Configuration
lambda_runtime = "python3.11"
lambda_timeout = 300
lambda_memory  = 512
