{
    "Comment": "Fixed Content Generator - \u043f\u0440\u0430\u0432\u0438\u043b\u044c\u043d\u0456 JSONPath",
    "StartAt": "GetActiveChannels",
    "States": {
        "GetActiveChannels": {
            "Type": "Task",
            "Resource": "arn:aws:states:::lambda:invoke",
            "Parameters": {
                "FunctionName": "arn:aws:lambda:eu-central-1:599297130956:function:content-get-channels",
                "Payload": {}
            },
            "ResultPath": "$.channelsResult",
            "Next": "ForEachChannel"
        },
        "ForEachChannel": {
            "Type": "Map",
            "ItemsPath": "$.channelsResult.Payload",
            "Iterator": {
                "StartAt": "QueryTitles",
                "States": {
                    "QueryTitles": {
                        "Type": "Task",
                        "Resource": "arn:aws:states:::lambda:invoke",
                        "Parameters": {
                            "FunctionName": "arn:aws:lambda:eu-central-1:599297130956:function:content-query-titles",
                            "Payload": {
                                "channel_id.$": "$.channel_id",
                                "config_id.$": "$.config_id",
                                "channel_name.$": "$.channel_name",
                                "genre.$": "$.genre"
                            }
                        },
                        "ResultPath": "$.queryResult",
                        "Next": "ThemeAgent"
                    },
                    "ThemeAgent": {
                        "Type": "Task",
                        "Resource": "arn:aws:states:::lambda:invoke",
                        "Parameters": {
                            "FunctionName": "arn:aws:lambda:eu-central-1:599297130956:function:content-theme-agent",
                            "Payload": {
                                "channel_id.$": "$.channel_id",
                                "channel_name.$": "$.channel_name",
                                "genre.$": "$.genre",
                                "titles.$": "$.queryResult.Payload.titles"
                            }
                        },
                        "ResultPath": "$.themeResult",
                        "Next": "SelectTopic"
                    },
                    "SelectTopic": {
                        "Type": "Task",
                        "Resource": "arn:aws:states:::lambda:invoke",
                        "Parameters": {
                            "FunctionName": "arn:aws:lambda:eu-central-1:599297130956:function:content-select-topic",
                            "Payload": {
                                "channel_id.$": "$.channel_id",
                                "generated_titles.$": "$.themeResult.Payload.generated_titles"
                            }
                        },
                        "ResultPath": "$.selectResult",
                        "Next": "NarrativeArchitect"
                    },
                    "NarrativeArchitect": {
                        "Type": "Task",
                        "Resource": "arn:aws:states:::lambda:invoke",
                        "Parameters": {
                            "FunctionName": "arn:aws:lambda:eu-central-1:599297130956:function:content-narrative",
                            "Payload": {
                                "channel_id.$": "$.channel_id",
                                "selected_topic.$": "$.selectResult.Payload.selected_topic"
                            }
                        },
                        "ResultPath": "$.narrativeResult",
                        "Next": "SaveResult"
                    },
                    "SaveResult": {
                        "Type": "Task",
                        "Resource": "arn:aws:states:::lambda:invoke",
                        "Parameters": {
                            "FunctionName": "arn:aws:lambda:eu-central-1:599297130956:function:content-save-result",
                            "Payload": {
                                "channel_id.$": "$.channel_id",
                                "topic.$": "$.selectResult.Payload.selected_topic",
                                "narrative.$": "$.narrativeResult.Payload.narrative_content",
                                "status": "completed"
                            }
                        },
                        "End": true
                    }
                }
            },
            "End": true
        }
    }
}
